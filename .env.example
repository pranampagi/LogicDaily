# Application environment (development/production)
ENV=development

# Secret key to authenticate rotation cron jobs
CRON_KEY=dev_cron_key

# SQLite or PostgreSQL Database connection string
# Examples:
# DATABASE_URL=sqlite:///./backend/logicdaily.db
# DATABASE_URL=postgresql://user:password@localhost:5432/logicdaily
DATABASE_URL=

# Database pool configurations (PostgreSQL only)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis configuration url for caching
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
